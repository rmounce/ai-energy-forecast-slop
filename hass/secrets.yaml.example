# HA secrets required by package-emhass.yaml.
# Copy to /opt/dockerfiles/hass/config/secrets.yaml (or merge into existing secrets.yaml).
# Do NOT commit the live secrets.yaml to the repo.

# EMHASS addon base URLs — replace YOURHOSTNAME with the actual internal hostname or IP.
emhass_url_optim: "http://emhass.YOURHOSTNAME/action/naive-mpc-optim"
emhass_url_publish: "http://emhass.YOURHOSTNAME/action/publish-data"
